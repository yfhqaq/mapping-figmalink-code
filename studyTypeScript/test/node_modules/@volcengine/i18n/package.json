{
  "name": "@volcengine/i18n",
  "version": "1.0.5",
  "description": "starling火山引擎文案拉取和替换工具",
  "author": "wangyu.1027@bytedance.com",
  "scripts": {
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --runInBand --watch --coverage",
    "build": "NODE_ENV=production eden-lib build",
    "start": "eden-lib start"
  },
  "files": [
    "dist",
    "open source notice.txt"
  ],
  "main": "./dist/react.js",
  "module": "./dist/react.js",
  "sideEffects": false,
  "dependencies": {
    "@panter/vue-i18next": "^0.15.2",
    "i18next": "^21.5.4",
    "i18next-vue": "^2.1.0",
    "lru-cache": "^6.0.0",
    "node-schedule": "^2.1.0",
    "react-i18next": "^11.14.3",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^10.0.0",
    "@commitlint/config-conventional": "^10.0.0",
    "@ies/create-eden-config": "^1.2.2",
    "@ies/eden-lib-build": "^1.0.1",
    "@ies/eden-lint": "^3.4.2",
    "@ies/intl-react-plugin": "^0.4.1",
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-node-resolve": "^13.0.6",
    "@types/jest": "^26.0.1",
    "@types/lru-cache": "^5.1.1",
    "@types/node-schedule": "^1.3.2",
    "@types/request": "^2.48.7",
    "husky": "4.2.5",
    "jest": "^26.4.2",
    "lint-staged": "^10.1.3",
    "ts-jest": "^26.4.0",
    "ttypescript": "^1.5.10",
    "typescript": "^4.0.2",
    "typescript-transform-paths": "^2.2.3"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint .commitlintrc.js -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*": [
      "eden-lint"
    ]
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
