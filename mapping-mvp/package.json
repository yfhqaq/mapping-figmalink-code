{
  "name": "mapping-mvp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "codeconnect:parse": "npx figma connect parse --config figma.config.json --outFile code-connect.json",
    "codeconnect:parse:stdout": "npx figma connect parse --config figma.config.json",
    "mapping:generate": "node --loader tsx scripts/generate-llm-mapping.ts",
    "mapping:evaluate": "node --loader tsx scripts/evaluate-mapping.ts",
    "mapping:fetch": "node --loader tsx scripts/fetch-figma-json.ts",
    "mapping:pipeline": "node --loader tsx scripts/evaluate-pipeline.ts",
    "mcp:serve": "node --loader tsx mcp/server.ts --stdio",
    "figma:list-components": "npx -y tsx scripts/list-components-from-url.ts",
    "figma:check-sds": "npx -y tsx scripts/check-sds-usage.ts",
    "mapping:update-status": "npx -y tsx scripts/update-component-mapping-status.ts",
    "mapping:update-registry": "npx -y tsx scripts/update-component-registry.ts",
    "mapping:list-presets": "npx -y tsx scripts/update-component-registry.ts -- --list-presets"
  },
  "dependencies": {
    "@figma/code-connect": "^1.3.12",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.17.2",
    "@types/react": "^19.2.10",
    "add": "^2.0.6",
    "tsx": "^4.19.2"
  }
}
