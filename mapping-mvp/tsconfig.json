{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "typeRoots": ["./types"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/**/*.ts",
    "mapping.business.ts",
    "business/**/*.ts",
    "types/**/*.d.ts"
  ]
}
